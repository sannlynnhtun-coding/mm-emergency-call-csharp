@inherits LayoutComponentBase
@inject AuthState AuthState
@inject NavigationManager Navigation

@if (AuthState.IsSignedIn)
{
    <div class="min-h-dvh bg-neutral-950 text-neutral-50">
        <div class="mx-auto flex min-h-dvh w-full max-w-7xl flex-col lg:flex-row">
            <aside class="border-b border-white/10 bg-neutral-950/95 px-4 py-4 lg:flex lg:w-72 lg:flex-col lg:border-b-0 lg:border-r lg:px-5 lg:py-6">
                <div class="flex items-center justify-between gap-4 lg:block">
                    <a class="flex min-h-11 items-center gap-3 rounded-md focus:outline-none focus:ring-2 focus:ring-red-400" href="/dashboard">
                        <span class="grid size-10 place-items-center rounded-md bg-red-600 text-sm font-bold text-white shadow-lg shadow-red-950/40">MM</span>
                        <span>
                            <span class="block text-sm font-semibold leading-5">MM Emergency Call</span>
                            <span class="block text-xs leading-5 text-neutral-400">Admin Portal</span>
                        </span>
                    </a>
                </div>

                <nav class="mt-6 grid gap-5" aria-label="Admin portal">
                    @foreach (var section in NavSections)
                    {
                        <div class="space-y-2">
                            <p class="px-3 text-xs font-semibold uppercase text-neutral-500">@section.Label</p>
                            <div class="space-y-1">
                                @foreach (var item in section.Items)
                                {
                                    <NavLink class="flex min-h-11 items-center rounded-md px-3 text-sm font-medium text-neutral-300 transition hover:bg-white/10 hover:text-white focus:outline-none focus:ring-2 focus:ring-red-400"
                                             ActiveClass="bg-red-600 text-white shadow-lg shadow-red-950/30"
                                             Match="@item.Match"
                                             href="@item.Href">
                                        @item.Label
                                    </NavLink>
                                }
                            </div>
                        </div>
                    }
                </nav>

                <div class="mt-6 border-t border-white/10 pt-5 lg:mt-auto">
                    <p class="px-3 text-xs font-semibold uppercase text-neutral-500">Account</p>
                    <div class="mt-3 rounded-md border border-white/10 bg-white/5 p-3">
                        <p class="truncate text-sm font-medium text-white">@AuthState.User?.Name</p>
                        <p class="mt-1 truncate text-xs text-neutral-400">@AuthState.User?.Email</p>
                        <div class="mt-3">
                            <Button Variant="outline" OnClick="SignOut">Sign out</Button>
                        </div>
                    </div>
                </div>
            </aside>

            <div class="flex min-w-0 flex-1 flex-col bg-neutral-50 text-neutral-950">
                <header class="sticky top-0 z-20 border-b border-neutral-200 bg-white/90 px-4 py-3 backdrop-blur lg:px-8">
                    <div class="flex min-h-11 items-center justify-between gap-4">
                        <div>
                            <p class="text-xs font-medium uppercase text-red-700">Admin Portal</p>
                            <p class="text-sm text-neutral-500">@AuthState.User?.Email</p>
                        </div>
                    </div>
                </header>

                <main class="flex-1 px-4 py-6 lg:px-8 lg:py-8">
                    @Body
                </main>
            </div>
        </div>
    </div>
}
else
{
    @Body
}

@code {
    private static readonly NavSection[] NavSections =
    [
        new("Overview",
        [
            new("Dashboard", "/dashboard", NavLinkMatch.All)
        ]),
        new("Operations",
        [
            new("Emergency Requests", "/emergency-requests")
        ]),
        new("Services",
        [
            new("Emergency Services", "/emergency-services"),
            new("Service Approvals", "/service-approvals")
        ]),
        new("Users",
        [
            new("Users", "/users")
        ]),
        new("Locations",
        [
            new("Townships", "/townships"),
            new("State Regions", "/state-regions")
        ])
    ];

    private void SignOut()
    {
        AuthState.SignOut();
        Navigation.NavigateTo("/login", replace: true);
    }

    private sealed record NavSection(string Label, NavItem[] Items);

    private sealed record NavItem(string Label, string Href, NavLinkMatch Match = NavLinkMatch.Prefix);
}
