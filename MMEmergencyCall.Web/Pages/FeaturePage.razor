    private static string StatusVariant(string? status)
    {
        return string.Equals(status, "Pending", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(status, "Rejected", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(status, "Cancel", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(status, "Deleted", StringComparison.OrdinalIgnoreCase)
            ? "danger"
            : "muted";
    }

    private static bool IsFinalRequestStatus(string? status)
    {
        return string.Equals(status, "Completed", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(status, "Closed", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(status, "Cancel", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsDeleted(string? status)
    {
        return string.Equals(status, "Deleted", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsActivated(string? status)
    {
        return string.Equals(status, "Activated", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsDeactivated(string? status)
    {
        return string.Equals(status, "Deactivated", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsApproved(string? status)
    {
        return string.Equals(status, "Approved", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsRejected(string? status)
    {
        return string.Equals(status, "Rejected", StringComparison.OrdinalIgnoreCase);
    }

    private string DeleteActionKey(int id)
    {
        return $"{Path}:{id}";
    }

    private static string WithQuery(string path, params (string Name, string? Value)[] values)
    {
        var query = values
            .Where(x => !string.IsNullOrWhiteSpace(x.Value))
            .Select(x => $"{Uri.EscapeDataString(x.Name)}={Uri.EscapeDataString(x.Value!)}")
            .ToList();

        return query.Count == 0 ? path : $"{path}?{string.Join("&", query)}";
    }

