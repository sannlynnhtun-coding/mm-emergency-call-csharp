@page "/emergency-requests"
@page "/emergency-services"
@page "/service-approvals"
@page "/users"
@page "/townships"
@page "/state-regions"
@inject ApiClient ApiClient
@inject AuthState AuthState
@inject NavigationManager Navigation

<PageTitle>@Current.Title</PageTitle>

<section class="space-y-6">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
            <Badge Variant="danger">@Current.Group</Badge>
            <h1 class="mt-3 text-3xl font-semibold tracking-normal text-neutral-950">@Current.Title</h1>
            <p class="mt-2 max-w-2xl text-sm leading-6 text-neutral-600">@Current.Description</p>
        </div>
        <Button Variant="outline" OnClick="LoadAsync" Disabled="@_isLoading">Refresh</Button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_actionError))
    {
        <Alert Variant="danger">@_actionError</Alert>
    }
    else if (!string.IsNullOrWhiteSpace(_actionMessage))
    {
        <Alert>@_actionMessage</Alert>
    }

    @if (_isLoading)
    {
        <div class="h-96 animate-pulse rounded-md bg-neutral-200"></div>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <Alert Variant="danger">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                <span>@_error</span>
                <Button Variant="danger" OnClick="LoadAsync">Retry</Button>
            </div>
        </Alert>
    }
    else
    {
        <div class="grid gap-4 lg:grid-cols-[1.2fr_0.8fr]">
            <Card Class="p-5">
                <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                    <div>
                        <h2 class="text-lg font-semibold text-neutral-950">@Current.TableTitle</h2>
                        <p class="mt-1 text-sm text-neutral-600">@Current.TableSubtitle</p>
                    </div>
                    <div class="flex flex-wrap items-center gap-2">
                        <Badge Variant="muted">@_rows.Count rows</Badge>
                        @if (_hasPagination)
                        {
                            <Button Variant="outline" OnClick="PreviousPageAsync" Disabled="@(!_canGoPrevious)">Previous</Button>
                            <span class="text-sm font-medium tabular-nums text-neutral-600">@_pageLabel</span>
                            <Button Variant="outline" OnClick="NextPageAsync" Disabled="@(!_canGoNext)">Next</Button>
                        }
                    </div>
                </div>

                <div class="mt-5 overflow-hidden rounded-md border border-neutral-200">
                    <table class="w-full text-left text-sm">
                        <thead class="bg-neutral-50 text-xs uppercase text-neutral-500">
                            <tr>
                                <th class="px-3 py-3 font-medium">Name</th>
                                <th class="px-3 py-3 font-medium">Status</th>
                                <th class="px-3 py-3 text-right font-medium">Detail</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-neutral-200 bg-white">
                            @if (_rows.Count == 0)
                            {
                                <tr>
                                    <td class="px-3 py-8 text-center text-neutral-600" colspan="3">@Current.EmptyText</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var row in _rows)
                                {
                                    <tr>
                                        <td class="px-3 py-3">
                                            <p class="font-medium text-neutral-950">@row.Name</p>
                                            <p class="text-xs text-neutral-500">@row.Secondary</p>
                                        </td>
                                        <td class="px-3 py-3">
                                            <Badge Variant="@row.BadgeVariant">@row.Status</Badge>
                                        </td>
                                        <td class="px-3 py-3 text-right text-neutral-600">
                                            @if (CanApproveServices && row.Id.HasValue)
                                            {
                                                <div class="flex flex-wrap justify-end gap-2">
                                                    <Button OnClick='@(() => UpdateServiceStatusAsync(row.Id.Value, "Approved"))' Disabled="@_actionId.HasValue">Approve</Button>
                                                    <Button Variant="outline" OnClick='@(() => UpdateServiceStatusAsync(row.Id.Value, "Rejected"))' Disabled="@_actionId.HasValue">Reject</Button>
                                                </div>
                                            }
                                            else if (CanUpdateRequests && row.Id.HasValue && !IsFinalRequestStatus(row.Status))
                                            {
                                                <div class="grid justify-items-end gap-2">
                                                    <span>@row.Detail</span>
                                                    <div class="flex flex-wrap justify-end gap-2">
                                                        <Button OnClick='@(() => UpdateRequestStatusAsync(row.Id.Value, "Completed"))' Disabled="@_actionId.HasValue">Complete</Button>
                                                        <Button Variant="outline" OnClick='@(() => UpdateRequestStatusAsync(row.Id.Value, "Closed"))' Disabled="@_actionId.HasValue">Close</Button>
                                                        <Button Variant="danger" OnClick='@(() => UpdateRequestStatusAsync(row.Id.Value, "Cancel"))' Disabled="@_actionId.HasValue">Cancel</Button>
                                                    </div>
                                                </div>
                                            }
                                            else if (CanDeleteRows && row.Id.HasValue && !IsDeleted(row.Status))
                                            {
                                                <div class="grid justify-items-end gap-2">
                                                    <span>@row.Detail</span>
                                                    @if (_confirmActionKey == DeleteActionKey(row.Id.Value))
                                                    {
                                                        <div class="flex flex-wrap justify-end gap-2">
                                                            <Button Variant="ghost" OnClick="CancelDelete" Disabled="@_actionId.HasValue">Cancel</Button>
                                                            <Button Variant="danger" OnClick="@(() => DeleteRowAsync(row.Id.Value))" Disabled="@_actionId.HasValue">Confirm Delete</Button>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="flex flex-wrap justify-end gap-2">
                                                            @if (CanCreateLocations)
                                                            {
                                                                <Button Variant="ghost" OnClick="@(() => LoadLocationDetailAsync(row.Id.Value))" Disabled="@(_actionId.HasValue || _isLocationDetailLoading)">Details</Button>
                                                                <Button Variant="outline" OnClick="@(() => StartEdit(row))" Disabled="@(_actionId.HasValue || _isSaving)">Edit</Button>
                                                            }
                                                            @if (CanManageServices && row.Service is not null)
                                                            {
                                                                <Button Variant="outline" OnClick="@(() => StartServiceEdit(row))" Disabled="@(_actionId.HasValue || _isSaving)">Edit</Button>
                                                                @if (!IsApproved(row.Status))
                                                                {
                                                                    <Button OnClick='@(() => UpdateServiceStatusAsync(row.Id.Value, "Approved"))' Disabled="@_actionId.HasValue">Approve</Button>
                                                                }
                                                                @if (!IsRejected(row.Status))
                                                                {
                                                                    <Button Variant="outline" OnClick='@(() => UpdateServiceStatusAsync(row.Id.Value, "Rejected"))' Disabled="@_actionId.HasValue">Reject</Button>
                                                                }
                                                            }
                                                            @if (CanUpdateUsers && row.User is not null)
                                                            {
                                                                <Button Variant="ghost" OnClick="@(() => LoadUserDetailAsync(row.Id.Value))" Disabled="@(_actionId.HasValue || _isUserDetailLoading)">Details</Button>
                                                                <Button Variant="outline" OnClick="@(() => StartUserEdit(row))" Disabled="@(_actionId.HasValue || _isSaving)">Edit</Button>
                                                                @if (!IsActivated(row.Status))
                                                                {
                                                                    <Button OnClick='@(() => UpdateUserStatusAsync(row, "Activated"))' Disabled="@_actionId.HasValue">Activate</Button>
                                                                }
                                                                @if (!IsDeactivated(row.Status))
                                                                {
                                                                    <Button Variant="outline" OnClick='@(() => UpdateUserStatusAsync(row, "Deactivated"))' Disabled="@_actionId.HasValue">Deactivate</Button>
                                                                }
                                                            }
                                                            <Button Variant="danger" OnClick="@(() => AskDelete(row.Id.Value))" Disabled="@_actionId.HasValue">Delete</Button>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                @row.Detail
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </Card>

            <Card Class="p-5">
                <h2 class="text-lg font-semibold text-neutral-950">Workspace</h2>
                <div class="mt-5 grid gap-3">
                    @if (CanCreateLocations)
                    {
                        <form class="rounded-md border border-neutral-200 bg-neutral-50 p-4" @onsubmit="CreateLocationAsync" @onsubmit:preventDefault="true">
                            <p class="text-sm font-medium text-neutral-950">Create @CreateLocationLabel</p>
                            <div class="mt-3 grid gap-3">
                                <Input Label="Code" Value="@_createCode" ValueChanged="@(value => _createCode = value)" Required="true" Disabled="@_isSaving" />
                                <Input Label="English name" Value="@_createNameEn" ValueChanged="@(value => _createNameEn = value)" Required="true" Disabled="@_isSaving" />
                                <Input Label="Myanmar name" Value="@_createNameMm" ValueChanged="@(value => _createNameMm = value)" Required="true" Disabled="@_isSaving" />
                                @if (Path == "/townships")
                                {
                                    <Input Label="State region code" Value="@_createStateRegionCode" ValueChanged="@(value => _createStateRegionCode = value)" Required="true" Disabled="@_isSaving" />
                                }
                                <Button Type="submit" Disabled="@_isSaving">Create</Button>
                            </div>
                        </form>
                    }
                    @if (_editId.HasValue && CanCreateLocations)
                    {
                        <form class="rounded-md border border-red-200 bg-red-50 p-4" @onsubmit="UpdateLocationAsync" @onsubmit:preventDefault="true">
                            <p class="text-sm font-medium text-neutral-950">Edit @CreateLocationLabel</p>
                            <div class="mt-3 grid gap-3">
                                <Input Label="Code" Value="@_editCode" ValueChanged="@(value => _editCode = value)" Required="true" Disabled="@_isSaving" />
                                <Input Label="English name" Value="@_editNameEn" ValueChanged="@(value => _editNameEn = value)" Required="true" Disabled="@_isSaving" />
                                <Input Label="Myanmar name" Value="@_editNameMm" ValueChanged="@(value => _editNameMm = value)" Required="true" Disabled="@_isSaving" />
                                @if (Path == "/townships")
                                {
                                    <Input Label="State region code" Value="@_editStateRegionCode" ValueChanged="@(value => _editStateRegionCode = value)" Required="true" Disabled="@_isSaving" />
                                }
                                <div class="flex flex-wrap gap-2">
                                    <Button Type="submit" Disabled="@_isSaving">Save</Button>
                                    <Button Variant="ghost" OnClick="CancelEdit" Disabled="@_isSaving">Cancel</Button>
                                </div>
                            </div>
                        </form>
                    }
                    @if (CanCreateLocations && _locationDetail is not null)
                    {
                        <div class="rounded-md border border-neutral-200 bg-neutral-50 p-4">
                            <div class="flex items-center justify-between gap-3">
                                <p class="text-sm font-medium text-neutral-950">@_locationDetail.NameEn</p>
                                <Badge Variant="muted">@_locationDetail.Code</Badge>
                            </div>
                            <div class="mt-3 grid gap-2 text-sm text-neutral-600">
                                <p>@TextOrFallback(_locationDetail.NameMm, "No Myanmar name")</p>
                                @if (!string.IsNullOrWhiteSpace(_locationDetail.ParentCode))
                                {
                                    <p>State region / @_locationDetail.ParentCode</p>
                                }
                            </div>
                        </div>
                    }
                    @if (CanCreateUsers)
                    {
                        <form class="rounded-md border border-neutral-200 bg-neutral-50 p-4" @onsubmit="SaveUserAsync" @onsubmit:preventDefault="true">
                            <p class="text-sm font-medium text-neutral-950">@(_userEditId.HasValue ? "Edit user" : "Create user")</p>
                            <div class="mt-3 grid gap-3">
                                <Input Label="Name" Value="@_userName" ValueChanged="@(value => _userName = value)" Required="true" Disabled="@_isSaving" />
                                <Input Label="Email" Type="email" Value="@_userEmail" ValueChanged="@(value => _userEmail = value)" Required="true" Disabled="@_isSaving" />
                                @if (!_userEditId.HasValue)
                                {
                                    <Input Label="Password" Type="password" Value="@_userPassword" ValueChanged="@(value => _userPassword = value)" Required="true" Disabled="@_isSaving" />
                                }
                                <Input Label="Phone number" Type="tel" Value="@_userPhoneNumber" ValueChanged="@(value => _userPhoneNumber = value)" Required="true" Disabled="@_isSaving" />
                                <Input Label="Address" Value="@_userAddress" ValueChanged="@(value => _userAddress = value)" Required="true" Disabled="@_isSaving" />
                                <Input Label="Township code" Value="@_userTownshipCode" ValueChanged="@(value => _userTownshipCode = value)" Required="true" Disabled="@_isSaving" />
                                <label class="grid gap-1 text-sm text-neutral-700">
                                    <span>Role</span>
                                    <select class="min-h-11 rounded-md border border-neutral-300 bg-white px-3 text-sm text-neutral-950 shadow-sm focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-500/30 disabled:cursor-not-allowed disabled:opacity-50" value="@_userRole" @onchange="UserRoleChanged" disabled="@_isSaving">
                                        @foreach (var role in RoleOptions)
                                        {
                                            <option value="@role">@role</option>
                                        }
                                    </select>
                                </label>
                                <div class="flex flex-wrap gap-2">
                                    <Button Type="submit" Disabled="@_isSaving">@(_userEditId.HasValue ? "Save" : "Create")</Button>
                                    @if (_userEditId.HasValue)
                                    {
                                        <Button Variant="ghost" OnClick="CancelUserEdit" Disabled="@_isSaving">Cancel</Button>
                                    }
                                </div>
                            </div>
                        </form>
                    }
                    @if (CanUpdateUsers && _userDetail is not null)
                    {
                        <div class="rounded-md border border-neutral-200 bg-neutral-50 p-4">
                            <div class="flex items-center justify-between gap-3">
                                <p class="text-sm font-medium text-neutral-950">@_userDetail.Name</p>
                                <Badge Variant="@StatusVariant(_userDetail.UserStatus)">@_userDetail.UserStatus</Badge>
                            </div>
                            <div class="mt-3 grid gap-2 text-sm text-neutral-600">
                                <p>@_userDetail.Email</p>
                                <p>@_userDetail.PhoneNumber</p>
                                <p>@_userDetail.Address</p>
                                <p>@_userDetail.Role / @TextOrFallback(_userDetail.TownshipCode, "No township")</p>
                                @if (!string.IsNullOrWhiteSpace(_userDetail.EmergencyType) || !string.IsNullOrWhiteSpace(_userDetail.EmergencyDetails))
                                {
                                    <p>@TextOrFallback(_userDetail.EmergencyType, "No emergency type") / @TextOrFallback(_userDetail.EmergencyDetails, "No details")</p>
                                }
                            </div>
                        </div>
                    }
                    @if (CanManageServices)
                    {
                        <form class="rounded-md border border-neutral-200 bg-neutral-50 p-4" @onsubmit="SaveServiceAsync" @onsubmit:preventDefault="true">
                            <p class="text-sm font-medium text-neutral-950">@(_serviceEditId.HasValue ? "Edit emergency service" : "Create emergency service")</p>
                            <div class="mt-3 grid gap-3">
                                <Input Label="Service group" Value="@_serviceGroup" ValueChanged="@(value => _serviceGroup = value)" Required="true" Disabled="@_isSaving" />
                                <Input Label="Service type" Value="@_serviceType" ValueChanged="@(value => _serviceType = value)" Required="true" Disabled="@_isSaving" />
                                <Input Label="Service name" Value="@_serviceName" ValueChanged="@(value => _serviceName = value)" Required="true" Disabled="@_isSaving" />
                                <Input Label="Phone number" Type="tel" Value="@_servicePhoneNumber" ValueChanged="@(value => _servicePhoneNumber = value)" Required="true" Disabled="@_isSaving" />
                                <Input Label="Location" Value="@_serviceLocation" ValueChanged="@(value => _serviceLocation = value)" Disabled="@_isSaving" />
                                <Input Label="Availability" Value="@_serviceAvailability" ValueChanged="@(value => _serviceAvailability = value)" Disabled="@_isSaving" maxlength="1" />
                                <Input Label="Township code" Value="@_serviceTownshipCode" ValueChanged="@(value => _serviceTownshipCode = value)" Disabled="@_isSaving" />
                                <div class="flex flex-wrap gap-2">
                                    <Button Type="submit" Disabled="@_isSaving">@(_serviceEditId.HasValue ? "Save" : "Create")</Button>
                                    @if (_serviceEditId.HasValue)
                                    {
                                        <Button Variant="ghost" OnClick="CancelServiceEdit" Disabled="@_isSaving">Cancel</Button>
                                    }
                                </div>
                            </div>
                        </form>
                    }
                    @if (ShowStatusFilter || ShowRoleFilter)
                    {
                        <div class="rounded-md border border-neutral-200 bg-neutral-50 p-4">
                            <p class="text-sm font-medium text-neutral-950">Filters</p>
                            <div class="mt-3 grid gap-3">
                                @if (ShowStatusFilter)
                                {
                                    <label class="grid gap-1 text-sm text-neutral-700">
                                        <span>Status</span>
                                        <select class="min-h-11 rounded-md border border-neutral-300 bg-white px-3 text-sm text-neutral-950 shadow-sm focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-500/30" value="@_statusFilter" @onchange="StatusFilterChangedAsync">
                                            <option value="">All statuses</option>
                                            @foreach (var status in StatusOptions)
                                            {
                                                <option value="@status">@status</option>
                                            }
                                        </select>
                                    </label>
                                }
                                @if (ShowRoleFilter)
                                {
                                    <label class="grid gap-1 text-sm text-neutral-700">
                                        <span>Role</span>
                                        <select class="min-h-11 rounded-md border border-neutral-300 bg-white px-3 text-sm text-neutral-950 shadow-sm focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-500/30" value="@_roleFilter" @onchange="RoleFilterChangedAsync">
                                            <option value="">All roles</option>
                                            @foreach (var role in RoleOptions)
                                            {
                                                <option value="@role">@role</option>
                                            }
                                        </select>
                                    </label>
                                }
                            </div>
                        </div>
                    }
                    <div class="rounded-md border border-neutral-200 bg-neutral-50 p-4">
                        <p class="text-sm font-medium text-neutral-950">Loaded rows</p>
                        <p class="mt-1 text-2xl font-semibold tabular-nums text-red-700">@_rows.Count</p>
                    </div>
                    <div class="rounded-md border border-neutral-200 bg-neutral-50 p-4">
                        <p class="text-sm font-medium text-neutral-950">Page</p>
                        <p class="mt-1 text-2xl font-semibold tabular-nums text-red-700">@_pageLabel</p>
                    </div>
                </div>
            </Card>
        </div>
    }
</section>

@code {
    private FeaturePageInfo Current => Pages.GetValueOrDefault(Path, Pages["/emergency-requests"]);
    private string Path => new Uri(Navigation.Uri).AbsolutePath.ToLowerInvariant();
    private const int PageSize = 10;
    private static readonly string[] RequestStatusOptions = ["Open", "Closed", "Completed", "Cancel"];
    private static readonly string[] ServiceStatusOptions = ["Pending", "Approved", "Rejected", "Deleted"];
    private static readonly string[] UserStatusOptions = ["Pending", "Activated", "Deactivated", "Deleted"];
    private static readonly string[] RoleOptions = ["Admin", "Normal User", "Service Provider"];

    private List<TableRow> _rows = new();
    private int _pageNo = 1;
    private int _pageCount = 1;
    private string _pageLabel = "1";
    private string? _loadedPath;
    private string? _error;
    private string? _actionError;
    private string? _actionMessage;
    private string _statusFilter = string.Empty;
    private string _roleFilter = string.Empty;
    private string _createCode = string.Empty;
    private string _createNameEn = string.Empty;
    private string _createNameMm = string.Empty;
    private string _createStateRegionCode = string.Empty;
    private int? _editId;
    private string _editCode = string.Empty;
    private string _editNameEn = string.Empty;
    private string _editNameMm = string.Empty;
    private string _editStateRegionCode = string.Empty;
    private LocationDetail? _locationDetail;
    private string _userName = string.Empty;
    private string _userEmail = string.Empty;
    private string _userPassword = string.Empty;
    private string _userPhoneNumber = string.Empty;
    private string _userAddress = string.Empty;
    private string _userTownshipCode = string.Empty;
    private string _userRole = "Normal User";
    private string _userStatus = "Pending";
    private int? _userEditId;
    private UserDetail? _userDetail;
    private string _serviceGroup = string.Empty;
    private string _serviceType = string.Empty;
    private string _serviceName = string.Empty;
    private string _servicePhoneNumber = string.Empty;
    private string _serviceLocation = string.Empty;
    private string _serviceAvailability = string.Empty;
    private string _serviceTownshipCode = string.Empty;
    private int? _serviceEditId;
    private string? _confirmActionKey;
    private int? _actionId;
    private bool _hasPagination;
    private bool _isEndOfPage = true;
    private bool _isLoading;
    private bool _isSaving;
    private bool _isLocationDetailLoading;
    private bool _isUserDetailLoading;
    private bool _canGoPrevious => _hasPagination && !_isLoading && _pageNo > 1;
    private bool _canGoNext => _hasPagination && !_isLoading && !_isEndOfPage && _pageNo < _pageCount;
    private bool CanUpdateRequests => Path == "/emergency-requests";
    private bool CanApproveServices => Path == "/service-approvals";
    private bool CanDeleteRows => Path is "/emergency-services" or "/users" or "/townships" or "/state-regions";
    private bool CanCreateLocations => Path is "/townships" or "/state-regions";
    private bool CanCreateUsers => Path == "/users";
    private bool CanUpdateUsers => Path == "/users";
    private bool CanManageServices => Path == "/emergency-services";
    private string CreateLocationLabel => Path == "/townships" ? "township" : "state region";
    private bool ShowRoleFilter => Path == "/users";
    private bool ShowStatusFilter => Path is "/emergency-requests" or "/emergency-services" or "/users";
    private string[] StatusOptions => Path switch
    {
        "/emergency-requests" => RequestStatusOptions,
        "/emergency-services" => ServiceStatusOptions,
        "/users" => UserStatusOptions,
        _ => []
    };

    private static readonly Dictionary<string, FeaturePageInfo> Pages = new()
    {
        ["/emergency-requests"] = new("Operations", "Emergency Requests", "Monitor incoming and historical emergency request records.", "Request queue", "Latest admin request records.", "No emergency request records loaded."),
        ["/emergency-services"] = new("Services", "Emergency Services", "Manage service providers and emergency response coverage.", "Service directory", "Latest service provider records.", "No emergency service records loaded."),
        ["/service-approvals"] = new("Services", "Service Approvals", "Review provider approval and rejection workflow state.", "Approval queue", "Pending service approval records.", "No service approvals loaded."),
        ["/users"] = new("Users", "Users", "Review admin and service-provider account records.", "User directory", "Latest admin user records.", "No user records loaded."),
        ["/townships"] = new("Locations", "Townships", "Maintain township records used across emergency services.", "Township list", "Latest township records.", "No township records loaded."),
        ["/state-regions"] = new("Locations", "State Regions", "Maintain state and region records for service coverage.", "State region list", "Latest state and region records.", "No state region records loaded.")
    };

    protected override async Task OnParametersSetAsync()
    {
        if (!AuthState.IsSignedIn)
        {
            Navigation.NavigateTo("/login", replace: true);
            return;
        }

        if (_loadedPath != Path)
        {
            _pageNo = 1;
            _statusFilter = string.Empty;
            _roleFilter = string.Empty;
            ResetCreateForm();
            ResetEditForm();
            ResetLocationDetail();
            ResetUserForm();
            ResetUserDetail();
            ResetServiceForm();
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error = null;
        _actionError = null;
        _confirmActionKey = null;
        _rows = new();
        _loadedPath = Path;

        switch (Path)
        {
            case "/emergency-requests":
                await LoadPagedAsync<EmergencyRequestListItem>(
                    WithQuery($"api/admin/EmergencyRequestList/pageNo/{_pageNo}/pageSize/{PageSize}", ("status", _statusFilter)),
                    x => new TableRow($"Request #{x.RequestId}", $"User {x.UserId} / Service {x.ServiceId}", x.Status, x.RequestTime.ToLocalTime().ToString("g"), StatusVariant(x.Status), x.RequestId));
                break;
            case "/emergency-services":
                await LoadPagedAsync<EmergencyServiceListItem>(
                    WithQuery($"api/Admin/EmergencyService/pageNo/{_pageNo}/pageSize/{PageSize}", ("serviceStatus", _statusFilter)),
                    x => new TableRow(TextOrFallback(x.ServiceName, $"Service #{x.ServiceId}"), $"{x.ServiceType} / {x.PhoneNumber}", TextOrFallback(x.ServiceStatus, "Unknown"), TextOrFallback(x.TownshipCode, "No township"), StatusVariant(x.ServiceStatus), x.ServiceId, Service: new ServiceRow(x.ServiceGroup, x.ServiceType, x.ServiceName, x.PhoneNumber, x.Location, x.Availability, x.TownshipCode)));
                break;
            case "/service-approvals":
                await LoadPagedAsync<EmergencyServiceListItem>(
                    $"api/Admin/EmergencyService/pageNo/{_pageNo}/pageSize/{PageSize}?serviceStatus=Pending",
                    x => new TableRow(TextOrFallback(x.ServiceName, $"Service #{x.ServiceId}"), $"{x.ServiceType} / {x.PhoneNumber}", TextOrFallback(x.ServiceStatus, "Pending"), TextOrFallback(x.TownshipCode, "No township"), StatusVariant(x.ServiceStatus), x.ServiceId));
                break;
            case "/users":
                await LoadPagedAsync<UserListItem>(
                    WithQuery($"api/admin/UserList/pageNo/{_pageNo}/pageSize/{PageSize}", ("role", _roleFilter), ("userStatus", _statusFilter)),
                    x => new TableRow(TextOrFallback(x.Name, $"User #{x.UserId}"), $"{x.Email} / {x.Role}", TextOrFallback(x.UserStatus, "Unknown"), TextOrFallback(x.TownshipCode, "No township"), StatusVariant(x.UserStatus), x.UserId, User: new UserRow(x.Name, x.Email, x.PhoneNumber, x.Address, x.EmergencyType, x.EmergencyDetails, x.TownshipCode, x.Role)));
                break;
            case "/townships":
                await LoadPagedAsync<TownshipListItem>(
                    $"api/Township/pageNo/{_pageNo}/pageSize/{PageSize}",
                    x => new TableRow(TextOrFallback(x.TownshipNameEn, x.TownshipCode), x.TownshipNameMm, x.StateRegionCode, x.TownshipCode, "muted", x.TownshipId, x.TownshipCode, x.StateRegionCode));
                break;
            case "/state-regions":
                await LoadStateRegionsAsync();
                break;
        }

        _isLoading = false;
    }

