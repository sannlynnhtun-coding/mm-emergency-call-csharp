@page "/not-found"

<PageTitle>Not found</PageTitle>

<LayoutView Layout="@typeof(MainLayout)">
    <section class="mx-auto flex min-h-dvh max-w-xl flex-col items-center justify-center px-6 text-center">
        <Badge Variant="danger">404</Badge>
        <h1 class="mt-5 text-3xl font-semibold text-neutral-950">Page not found</h1>
        <p class="mt-3 text-neutral-600">The requested admin page is unavailable.</p>
        <a class="mt-6 inline-flex min-h-11 items-center rounded-md bg-red-600 px-4 text-sm font-medium text-white shadow-sm transition hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2" href="/dashboard">
            Back to dashboard
        </a>
    </section>
</LayoutView>
